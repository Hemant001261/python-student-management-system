import sqlite3

conn = sqlite3.connect("bank.db")
cursor = conn.cursor()

cursor.execute("""
CREATE TABLE IF NOT EXISTS accounts(
    account TEXT PRIMARY KEY,
    name TEXT,
    pin TEXT,
    balance REAL
)
""")
conn.commit()

while True:
    print("\n===== BANK MANAGEMENT SYSTEM =====")
    print("1. Create Account")
    print("2. Deposit")
    print("3. Withdraw")
    print("4. Check Balance")
    print("5. Exit")

    choice = input("Enter Choice: ")

    if choice == "1":
        account = input("Account Number: ")
        name = input("Name: ")
        pin = input("4 Digit PIN: ")
        balance = float(input("Opening Balance: "))

        cursor.execute(
            "INSERT INTO accounts VALUES (?,?,?,?)",
            (account, name, pin, balance)
        )
        conn.commit()
        print("✅ Account Created Successfully")

    elif choice == "2":
        account = input("Account Number: ")
        pin = input("PIN: ")

        cursor.execute(
            "SELECT balance FROM accounts WHERE account=? AND pin=?",
            (account, pin)
        )
        data = cursor.fetchone()

        if data:
            amount = float(input("Deposit Amount: "))
            new_balance = data[0] + amount

            cursor.execute(
                "UPDATE accounts SET balance=? WHERE account=?",
                (new_balance, account)
            )
            conn.commit()
            print("✅ Deposit Successful")
        else:
            print("❌ Invalid Account or PIN")e")

    elif choice == "3":
        account = input("Account Number: ")
        pin = input("PIN: ")

        cursor.execute(
            "SELECT balance FROM accounts WHERE account=? AND pin=?",
            (account, pin)
        )
        data = cursor.fetchone()

        if data:
            amount = float(input("Withdraw Amount: "))
            if data[0] >= amount:
                new_balance = data[0] - amount

                cursor.execute(
                    "UPDATE accounts SET balance=? WHERE account=?",
                    (new_balance, account)
                )
                conn.commit()
                print("✅ Withdrawal Successful")
            else:
                print("❌ Insufficient Balance")
        else:
            print("❌ Invalid Account or PIN")

    elif choice == "4":
        account = input("Account Number: ")
        pin = input("PIN: ")

        cursor.execute(
            "SELECT name, balance FROM accounts WHERE account=? AND pin=?",
            (account, pin)
        )
        data = cursor.fetchone()

        if data:
            print("\n===== ACCOUNT DETAILS =====")
            print("Name :", data[0])
            print("Balance :", data[1])
        else:
            print("❌ Invalid Account or PIN")

    elif choice == "5":
        print("Thank you for using Bank Management System.")
        conn.close()
        break

    else:
        print("❌ Invalid Choice")

